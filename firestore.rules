rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows a customer to read and write their own profile data.
     * @path /customers/{customerId}
     * @allow (get, create, update, delete) if request.auth.uid == customerId
     * @deny (get, create, update, delete) if request.auth.uid != customerId
     * @principle Enforces document ownership for all operations on customer profiles.
     */
    match /customers/{customerId} {
      // Check if the user is signed in
      function isSignedIn() {
        return request.auth != null;
      }

      // Check if the requested user id matches the authenticated user id
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      // Check if the user exists, and the requested user id matches the authenticated user id
      function isExistingOwner(userId) {
        return isOwner(userId) && exists(resource.path);
      }

      allow get: if isOwner(customerId);
      allow list: if false; // Listing all users is not permitted.
      allow create: if isSignedIn() && isOwner(customerId);
      allow update: if isOwner(customerId);
      allow delete: if isExistingOwner(customerId);
    }

    /**
     * @description Allows a customer to read and write their own order data.
     * @path /customers/{customerId}/orders/{orderId}
     * @allow (get, create, update, delete, list) if request.auth.uid == customerId
     * @deny (get, create, update, delete, list) if request.auth.uid != customerId
     * @principle Enforces document ownership for all operations on customer orders.
     */
    match /customers/{customerId}/orders/{orderId} {
        // Check if the user is signed in
      function isSignedIn() {
        return request.auth != null;
      }

      // Check if the requested user id matches the authenticated user id
      function isOwner(customerId) {
        return request.auth.uid == customerId;
      }

      // Check if the user exists, and the requested user id matches the authenticated user id
      function isExistingOwner(customerId) {
        return isOwner(customerId) && exists(resource.path);
      }

      allow get: if isOwner(customerId);
      allow list: if isOwner(customerId);
      allow create: if isOwner(customerId);
      allow update: if isOwner(customerId);
      allow delete: if isExistingOwner(customerId);
    }

    /**
     * @description Allows anyone to read service details, but only admins can create, update, or delete them.
     * @path /services/{serviceId}
     * @allow get, list: if true
     * @allow create, update, delete: if isAdmin()
     * @principle Allows public read access with restricted writes.
     */
    match /services/{serviceId} {
       // Check if the user is signed in
      function isSignedIn() {
        return request.auth != null;
      }

      // Check if the user has admin rights
      function isAdmin() {
        return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
      }

      allow get, list: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Allows anyone to create contact messages, but only admins can read, update, or delete them.
     * @path /contacts/{contactId}
     * @allow create: if true
     * @allow get, list, update, delete: if isAdmin()
     * @principle Allows public creation with restricted access for management.
     */
    match /contacts/{contactId} {
      // Check if the user is signed in
      function isSignedIn() {
        return request.auth != null;
      }

      // Check if the user has admin rights
      function isAdmin() {
        return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
      }

      allow get: if isAdmin();
      allow list: if isAdmin();
      allow create: if true;
      allow update: if isAdmin(); // No one is allowed to update contact messages in this prototype.
      allow delete: if isAdmin();
    }

    /**
     * @description Defines admin roles based on document existence.
     * @path /roles_admin/{uid}
     * @allow get, create, update, delete: if isAdmin()
     * @principle Uses DBAC (Database-Based Access Control) to grant admin privileges.
     */
    match /roles_admin/{uid} {
      // Check if the user is signed in
      function isSignedIn() {
        return request.auth != null;
      }

      // Check if the user has admin rights
      function isAdmin() {
        return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
      }

      // Allow only admins to manage admin roles.
      allow get: if isAdmin();
      allow list: if false; // No listing of admin roles
      allow create: if isAdmin();
      allow update: if isAdmin(); // No updating, only creation/deletion to modify admin privileges.
      allow delete: if isAdmin();
    }
  }
}