/**
 * @file Firebase Security Rules for Buddy Clean Firestore database.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for customer data,
 * restricts contact message access to admins, and allows public access to service data.
 * Admin privileges are granted based on the presence of a document in the `roles_admin` collection.
 *
 * Data Structure:
 * - /customers/{customerId}: Customer profile data, where customerId is the Firebase Auth UID.
 * - /customers/{customerId}/orders/{orderId}: Orders placed by a customer.  Each order contains a denormalized customerId.
 * - /services/{serviceId}: Publicly accessible data about cleaning services.
 * - /contacts/{contactId}: Contact form submissions, accessible only by admins.
 * - /roles_admin/{uid}: Admin role definitions; the existence of a document grants admin privileges.
 *
 * Key Security Decisions:
 * - Customers can only access their own profile data and orders.
 * - Listing all customers is prohibited.
 * - Services are publicly readable.
 * - Contact messages are only accessible to admins.
 * - Admin status is determined by the presence of a document in the `roles_admin` collection.
 *
 * Denormalization for Authorization:
 * - The `orders` collection denormalizes `customerId` to enable authorization checks without requiring `get()` calls to the `customers` collection.
 *
 * Structural Segregation:
 * - User data (customers and orders) is separated from public data (services) and admin data (contacts, admin roles).
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Rule for customer profile data. Only the authenticated user can read and write their own profile.
     * @path /customers/{customerId}
     * @allow (create, update, get, delete) if the user is signed in and the customerId matches their UID (e.g., create a profile for themselves).
     * @deny (create, update, get, delete) if the user is not signed in or the customerId does not match their UID (e.g., trying to access another user's profile).
     * @principle Enforces document ownership for all operations.
     */
    match /customers/{customerId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      allow get: if isOwner(customerId);
      allow list: if false;

      allow create: if isOwner(customerId);
      allow update: if isOwner(customerId);
      allow delete: if isOwner(customerId);
    }

    /**
     * @description Rule for orders placed by a customer. Only the customer who owns the order can access it.
     * @path /customers/{customerId}/orders/{orderId}
     * @allow (create, update, get, delete) if the user is signed in, the customerId matches their UID, and the order's customerId also matches their UID (e.g., create an order for themselves).
     * @deny (create, update, get, delete) if the user is not signed in or the customerId does not match their UID (e.g., trying to access another user's order).
     * @principle Enforces document ownership and validates data consistency.
     */
    match /customers/{customerId}/orders/{orderId} {
      function isOwner(customerId) {
        return request.auth != null && request.auth.uid == customerId;
      }

      allow get: if isOwner(customerId);
      allow list: if isOwner(customerId);

      allow create: if isOwner(customerId);
      allow update: if isOwner(customerId);
      allow delete: if isOwner(customerId);
    }

    /**
     * @description Rule for cleaning services. These are publicly accessible.
     * @path /services/{serviceId}
     * @allow (get, list) any user can read service details.
     * @deny (create, update, delete) only admins can create, update, or delete services (TODO: Implement admin check).
     * @principle Allows public read access to service information.
     */
    match /services/{serviceId} {
      allow get: if true;
      allow list: if true;
      allow create, update, delete: if false; // TODO: Add admin validation once admin role is implemented.
    }

    /**
     * @description Rule for contact form submissions. Only admins can access these messages.
     * @path /contacts/{contactId}
     * @allow (get, list, create, update, delete) only if the user has admin privileges.
     * @deny (get, list, create, update, delete) if the user is not an admin.
     * @principle Restricts access to sensitive contact information to authorized personnel.
     */
    match /contacts/{contactId} {
      function isAdmin() {
        return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
      }

      function isSignedIn() {
          return request.auth != null;
      }

      allow get: if isSignedIn() && isAdmin();
      allow list: if isSignedIn() && isAdmin();

      allow create: if isSignedIn() && isAdmin();
      allow update: if isSignedIn() && isAdmin();
      allow delete: if isSignedIn() && isAdmin();
    }

    /**
     * @description Rule for admin role definitions.  Creating a document with a UID grants admin privileges.
     * @path /roles_admin/{uid}
     * @allow create: if the UID matches the authenticated user's UID (self-assignment, for initial setup).
     * @allow get: if the UID matches the authenticated user's UID (self-check).
     * @deny create, get, update, delete for any other users.
     */
    match /roles_admin/{uid} {
        function isOwner(uid) {
            return request.auth != null && request.auth.uid == uid;
        }

        allow get: if isOwner(uid);
        allow list: if false;

        allow create: if isOwner(uid);
        allow update: if false;
        allow delete: if false;
    }
  }
}